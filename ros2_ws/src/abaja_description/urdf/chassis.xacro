    <visual>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry><box size="0.35 0.04 0.04"/></geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry><box size="0.35 0.04 0.04"/></geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.35" y_dim="0.04" z_dim="0.04"/>
  </link>
  <joint name="chassis_to_rr_suspension" type="fixed">
    <parent link="chassis_link"/>
    <child  link="rear_right_suspension_arm"/>
    <origin xyz="0 -${chassis_width/2 + 0.08} -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Rear right spring (ORANGE) -->
  <link name="rear_right_spring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.26"/></geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.26"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.025" length="0.26"/>
  </link>
  <joint name="chassis_to_rr_spring" type="fixed">
    <parent link="chassis_link"/>
    <child  link="rear_right_spring"/>
    <origin xyz="-0.05 -${chassis_width/2 + 0.05} ${-chassis_height/2 + 0.05}" rpy="0 -0.2 0"/>
  </joint>

  <!-- ======================================================================
    REAR SUBFRAME (preserved)
  ====================================================================== -->
  <link name="rear_subframe_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.52 0.62 0.10"/></geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.52 0.62 0.10"/></geometry>
    </collision>
    <xacro:box_inertia mass="12.0" x_dim="0.52" y_dim="0.62" z_dim="0.10"/>
  </link>
  <joint name="chassis_to_rear_subframe" type="fixed">
    <parent link="chassis_link"/>
    <child  link="rear_subframe_link"/>
    <origin xyz="-0.15 0 -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    FIRE EXTINGUISHER — Safety-red cylinder mounted on left side of cockpit
    Visual only. Fixed to chassis_link.
    Frame: fire_extinguisher_link
  ====================================================================== -->
  <link name="fire_extinguisher_link">
    <!-- Main extinguisher body (red cylinder) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
      <material name="FireExtRed"/>
    </visual>
    <!-- Top head / valve area (dark, slightly wider) -->
    <visual>
      <origin xyz="0 0 0.17" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.06"/></geometry>
      <material name="FireExtHead"/>
    </visual>
    <!-- Nozzle hose (thin cylinder, angled) -->
    <visual>
      <origin xyz="0.02 0 0.20" rpy="0 0.6 0"/>
      <geometry><cylinder radius="0.008" length="0.08"/></geometry>
      <material name="FireExtHead"/>
    </visual>
    <!-- Mounting bracket (flat box clamp) -->
    <visual>
      <origin xyz="-0.045 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.02 0.10 0.08"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Mounted on left side panel, mid-cockpit height, clearly visible -->
  <joint name="chassis_to_fire_extinguisher" type="fixed">
    <parent link="chassis_link"/>
    <child  link="fire_extinguisher_link"/>
    <!-- Left side, inside the cockpit area, visible when looking from the left -->
    <origin xyz="${wheelbase/2 + 0.30} ${chassis_width/2 + 0.06} ${chassis_height/2 + 0.35}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    SEATBELT / HARNESS CROSS-STRAPS
    Visual only — two diagonal straps crossing the seat area.
    Represents a 4-point / 6-point racing harness.
  ====================================================================== -->
  <!-- Left shoulder strap (diagonal from top-left to lap-centre) -->
  <link name="harness_left_strap">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.045 0.035 0.55"/></geometry>
      <material name="SeatBlack"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.045 0.035 0.55"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="seat_to_left_strap" type="fixed">
    <parent link="seat_link"/>
    <child  link="harness_left_strap"/>
    <!-- Left-of-centre, angled 20° toward centre (simulates shoulder→lap diagonal) -->
    <origin xyz="-0.05 0.10 0.32" rpy="0 0.35 0.18"/>
  </joint>

  <!-- Right shoulder strap -->
  <link name="harness_right_strap">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.045 0.035 0.55"/></geometry>
      <material name="SeatBlack"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.045 0.035 0.55"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="seat_to_right_strap" type="fixed">
    <parent link="seat_link"/>
    <child  link="harness_right_strap"/>
    <origin xyz="-0.05 -0.10 0.32" rpy="0 0.35 -0.18"/>
  </joint>

  <!-- Lap belt (horizontal across the seat bottom) -->
  <link name="harness_lap_belt">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.38 0.035"/></geometry>
      <material name="SeatRed"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.38 0.035"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="seat_to_lap_belt" type="fixed">
    <parent link="seat_link"/>
    <child  link="harness_lap_belt"/>
    <origin xyz="0.10 0 0.06" rpy="0 0 0"/>
  </joint>

</robot>
