<?xml version="1.0"?>
<!-- ============================================================================
  chassis.xacro - Chassis, body, roll cage, bumpers, cockpit for aBAJA Buggy

  VISUAL IMPROVEMENTS (over original):
  - Roll cage hoops now use cylinders (not boxes) for realistic tube look
  - Front hoop has proper left/top/right cylinder segments
  - Rear hoop same — identifiable from rear
  - Added: front bumper (orange accent) + front skid plate
  - Added: rear bumper + rear guard plate
  - Added: front nose body panel
  - Added: rear body panel
  - Added: two diagonal brace tubes on roll cage
  - Body panels (blue) extended to full cockpit height for visual depth
  - Tail lights repositioned to rear face
  - Added: front indicator lights (white) for front identification
  - Added: LiDAR mount link on sensor bar
  - All existing TF frames, joints, and Gazebo plugins preserved

  Coordinate system (base_link at rear axle center, ground level):
    X = forward, Y = left, Z = up

  Vehicle dimensions (unchanged):
    Wheelbase: 1.65 m
    Track: 1.25 m
    Wheel radius: 0.32 m
    Ground clearance: 0.25 m
============================================================================ -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="abaja_chassis">

  <!-- ======================================================================
    XACRO PROPERTIES
  ====================================================================== -->
  <xacro:property name="chassis_length" value="2.0"/>
  <xacro:property name="chassis_width"  value="0.85"/>
  <xacro:property name="chassis_height" value="0.15"/>
  <xacro:property name="chassis_mass"   value="80.0"/>
  <xacro:property name="ground_clearance" value="0.25"/>

  <xacro:property name="wheelbase"   value="1.65"/>
  <xacro:property name="track_width" value="1.25"/>

  <!-- Roll cage -->
  <xacro:property name="cage_tube_radius" value="0.025"/>
  <xacro:property name="cage_height"      value="1.15"/>

  <!-- Cockpit offset -->
  <xacro:property name="cockpit_offset_x" value="0.1"/>

  <!-- ======================================================================
    INERTIA MACROS
  ====================================================================== -->
  <xacro:macro name="box_inertia" params="mass x_dim y_dim z_dim">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y_dim*y_dim + z_dim*z_dim)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (x_dim*x_dim + z_dim*z_dim)}"
        iyz="0.0"
        izz="${(1.0/12.0) * mass * (x_dim*x_dim + y_dim*y_dim)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        iyz="0.0"
        izz="${(1.0/2.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(2.0/5.0) * mass * radius * radius}"
        ixy="0.0" ixz="0.0"
        iyy="${(2.0/5.0) * mass * radius * radius}"
        iyz="0.0"
        izz="${(2.0/5.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- ======================================================================
    TUBE MACRO - reusable cylinder visual for roll cage / frame tubes
    Reduces repetition for cage bars
    params: name, length, parent, xyz, rpy (joint origin), tube_mass
  ====================================================================== -->
  <xacro:macro name="cage_tube" params="link_name tube_len tube_mass parent_link jnt_x jnt_y jnt_z jnt_r jnt_p jnt_yaw vis_r vis_p vis_yaw">
    <link name="${link_name}">
      <visual>
        <origin xyz="0 0 0" rpy="${vis_r} ${vis_p} ${vis_yaw}"/>
        <geometry><cylinder radius="${cage_tube_radius}" length="${tube_len}"/></geometry>
        <material name="Steel"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${vis_r} ${vis_p} ${vis_yaw}"/>
        <geometry><cylinder radius="${cage_tube_radius}" length="${tube_len}"/></geometry>
      </collision>
      <xacro:cylinder_inertia mass="${tube_mass}" radius="${cage_tube_radius}" length="${tube_len}"/>
    </link>
    <joint name="${link_name}_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="${link_name}"/>
      <origin xyz="${jnt_x} ${jnt_y} ${jnt_z}" rpy="${jnt_r} ${jnt_p} ${jnt_yaw}"/>
    </joint>
  </xacro:macro>

  <!-- ======================================================================
    BASE AND REFERENCE LINKS (PRESERVED - do not change names)
  ====================================================================== -->
  <link name="dummy_root">
    <!-- Massless root link (KDL requirement) -->
  </link>

  <joint name="dummy_to_base" type="fixed">
    <parent link="dummy_root"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="base_footprint">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    CHASSIS_LINK - Main lower frame (preserved name/joint)
  ====================================================================== -->
  <link name="chassis_link">
    <!-- Main lower chassis tube frame (longitudinal rail) -->
    <visual>
      <origin xyz="${wheelbase/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="Black"/>
    </visual>
    <!-- Left chassis rail (visual highlight) -->
    <visual>
      <origin xyz="${wheelbase/2} ${chassis_width/2 + 0.01} 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} 0.05 ${chassis_height + 0.02}"/></geometry>
      <material name="DarkGrey"/>
    </visual>
    <!-- Right chassis rail -->
    <visual>
      <origin xyz="${wheelbase/2} -${chassis_width/2 + 0.01} 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} 0.05 ${chassis_height + 0.02}"/></geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="${wheelbase/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <xacro:box_inertia mass="${chassis_mass}" x_dim="${chassis_length}" y_dim="${chassis_width}" z_dim="${chassis_height}"/>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis_link"/>
    <origin xyz="0 0 ${ground_clearance}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    FLOOR PAN (preserved)
  ====================================================================== -->
  <link name="floor_pan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.0 ${chassis_width} 0.02"/></geometry>
      <material name="FloorGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.0 ${chassis_width} 0.02"/></geometry>
    </collision>
    <xacro:box_inertia mass="8.0" x_dim="1.0" y_dim="${chassis_width}" z_dim="0.02"/>
  </link>

  <joint name="chassis_to_floor" type="fixed">
    <parent link="chassis_link"/>
    <child  link="floor_pan_link"/>
    <origin xyz="${wheelbase/2 + 0.1} 0 ${chassis_height/2 + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    BODY PANELS - Left and right (improved: taller, team blue color)
  ====================================================================== -->
  <!-- Left body panel - full cockpit height, team blue -->
  <link name="left_body_panel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.15 0.025 0.52"/></geometry>
      <material name="BodyPanel"/>
    </visual>
    <!-- Panel stripe accent (lighter blue strip along top) -->
    <visual>
      <origin xyz="0 0 0.27" rpy="0 0 0"/>
      <geometry><box size="1.15 0.03 0.04"/></geometry>
      <material name="FrontNose"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.15 0.025 0.52"/></geometry>
    </collision>
    <xacro:box_inertia mass="3.5" x_dim="1.15" y_dim="0.025" z_dim="0.52"/>
  </link>

  <joint name="chassis_to_left_panel" type="fixed">
    <parent link="chassis_link"/>
    <child  link="left_body_panel_link"/>
    <origin xyz="${wheelbase/2 + 0.05} ${chassis_width/2 + 0.01} ${chassis_height/2 + 0.28}" rpy="0 0 0"/>
  </joint>

  <!-- Right body panel -->
  <link name="right_body_panel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.15 0.025 0.52"/></geometry>
      <material name="BodyPanel"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.27" rpy="0 0 0"/>
      <geometry><box size="1.15 0.03 0.04"/></geometry>
      <material name="FrontNose"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.15 0.025 0.52"/></geometry>
    </collision>
    <xacro:box_inertia mass="3.5" x_dim="1.15" y_dim="0.025" z_dim="0.52"/>
  </link>

  <joint name="chassis_to_right_panel" type="fixed">
    <parent link="chassis_link"/>
    <child  link="right_body_panel_link"/>
    <origin xyz="${wheelbase/2 + 0.05} -${chassis_width/2 + 0.01} ${chassis_height/2 + 0.28}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    FRONT NOSE PANEL - Gives the front a distinctive look
  ====================================================================== -->
  <link name="front_nose_link">
    <!-- Main angled nose plate -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0.25 0"/>
      <geometry><box size="0.35 ${chassis_width + 0.05} 0.38"/></geometry>
      <material name="BodyPanel"/>
    </visual>
    <!-- Nose accent stripe (orange) -->
    <visual>
      <origin xyz="0.04 0 0.18" rpy="0 0 0"/>
      <geometry><box size="0.04 ${chassis_width + 0.05} 0.04"/></geometry>
      <material name="BumperOrange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0.25 0"/>
      <geometry><box size="0.35 ${chassis_width + 0.05} 0.38"/></geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.35" y_dim="${chassis_width + 0.05}" z_dim="0.38"/>
  </link>

  <joint name="chassis_to_front_nose" type="fixed">
    <parent link="chassis_link"/>
    <child  link="front_nose_link"/>
    <origin xyz="${wheelbase + 0.82} 0 ${chassis_height/2 + 0.22}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    REAR BODY PANEL / REAR GUARD
  ====================================================================== -->
  <link name="rear_guard_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 ${chassis_width + 0.05} 0.42"/></geometry>
      <material name="RearGuard"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 ${chassis_width + 0.05} 0.42"/></geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.06" y_dim="${chassis_width + 0.05}" z_dim="0.42"/>
  </link>

  <joint name="chassis_to_rear_guard" type="fixed">
    <parent link="chassis_link"/>
    <child  link="rear_guard_link"/>
    <origin xyz="-0.15 0 ${chassis_height/2 + 0.24}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    FRONT BUMPER - Orange accent, clearly identifies front
  ====================================================================== -->
  <link name="front_bumper_link">
    <!-- Main bumper bar -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 ${track_width + 0.15} 0.08"/></geometry>
      <material name="BumperOrange"/>
    </visual>
    <!-- Left bumper horn -->
    <visual>
      <origin xyz="-0.08 ${track_width/2 + 0.05} 0" rpy="0 0 0.35"/>
      <geometry><box size="0.25 0.05 0.06"/></geometry>
      <material name="BumperOrange"/>
    </visual>
    <!-- Right bumper horn -->
    <visual>
      <origin xyz="-0.08 -${track_width/2 + 0.05} 0" rpy="0 0 -0.35"/>
      <geometry><box size="0.25 0.05 0.06"/></geometry>
      <material name="BumperOrange"/>
    </visual>
    <!-- Bumper skid plate (lower) -->
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry><box size="0.04 ${track_width + 0.15} 0.05"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 ${track_width + 0.15} 0.08"/></geometry>
    </collision>
    <xacro:box_inertia mass="3.0" x_dim="0.08" y_dim="${track_width + 0.15}" z_dim="0.08"/>
  </link>

  <joint name="chassis_to_front_bumper" type="fixed">
    <parent link="chassis_link"/>
    <child  link="front_bumper_link"/>
    <origin xyz="${wheelbase + 1.02} 0 ${-chassis_height/2 + 0.04}" rpy="0 0 0"/>
  </joint>

  <!-- Front indicator lights (white, mounted on bumper corners) -->
  <link name="front_left_light_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.04" length="0.025"/></geometry>
      <material name="FrontLight"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.04" length="0.025"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.05" radius="0.04" length="0.025"/>
  </link>

  <joint name="bumper_to_fl_light" type="fixed">
    <parent link="front_bumper_link"/>
    <child  link="front_left_light_link"/>
    <origin xyz="0.03 ${track_width/2 + 0.02} 0.02" rpy="0 0 0"/>
  </joint>

  <link name="front_right_light_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.04" length="0.025"/></geometry>
      <material name="FrontLight"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.04" length="0.025"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.05" radius="0.04" length="0.025"/>
  </link>

  <joint name="bumper_to_fr_light" type="fixed">
    <parent link="front_bumper_link"/>
    <child  link="front_right_light_link"/>
    <origin xyz="0.03 -${track_width/2 + 0.02} 0.02" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    REAR BUMPER
  ====================================================================== -->
  <link name="rear_bumper_link">
    <!-- Main rear bumper bar -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 ${track_width + 0.1} 0.07"/></geometry>
      <material name="BumperGrey"/>
    </visual>
    <!-- Rear tow hook visual -->
    <visual>
      <origin xyz="-0.05 0 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.08 0.04 0.04"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 ${track_width + 0.1} 0.07"/></geometry>
    </collision>
    <xacro:box_inertia mass="2.5" x_dim="0.06" y_dim="${track_width + 0.1}" z_dim="0.07"/>
  </link>

  <joint name="chassis_to_rear_bumper" type="fixed">
    <parent link="chassis_link"/>
    <child  link="rear_bumper_link"/>
    <origin xyz="-0.18 0 ${-chassis_height/2 + 0.03}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    ROLL CAGE - Proper cylindrical tubes for realistic look
    FRONT HOOP: left pillar + top cross + right pillar
    REAR HOOP:  left pillar + top cross + right pillar
    CONNECTIONS: top bar (L-R), diagonal braces
  ====================================================================== -->

  <!-- ── FRONT HOOP ─────────────────────────────────────────── -->
  <!-- Front hoop: left pillar (cylinder, vertical) -->
  <xacro:cage_tube
    link_name="roll_cage_front_left_upright"
    tube_len="${cage_height}"
    tube_mass="2.0"
    parent_link="chassis_link"
    jnt_x="${wheelbase/2 + 0.55}" jnt_y="${chassis_width/2 + 0.03}" jnt_z="${chassis_height/2 + cage_height/2}"
    jnt_r="0" jnt_p="0" jnt_yaw="0"
    vis_r="0" vis_p="0" vis_yaw="0"/>

  <!-- Front hoop: right pillar -->
  <xacro:cage_tube
    link_name="roll_cage_front_right_upright"
    tube_len="${cage_height}"
    tube_mass="2.0"
    parent_link="chassis_link"
    jnt_x="${wheelbase/2 + 0.55}" jnt_y="-${chassis_width/2 + 0.03}" jnt_z="${chassis_height/2 + cage_height/2}"
    jnt_r="0" jnt_p="0" jnt_yaw="0"
    vis_r="0" vis_p="0" vis_yaw="0"/>

  <!-- Front hoop: top cross tube (horizontal, Y direction) -->
  <link name="roll_cage_front_hoop">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="1.5" radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/>
  </link>
  <joint name="chassis_to_front_hoop" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_front_hoop"/>
    <origin xyz="${wheelbase/2 + 0.55} 0 ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- ── REAR HOOP ──────────────────────────────────────────── -->
  <!-- Rear hoop: left upright (with slight outward lean for BAJA style) -->
  <link name="roll_cage_left_rear_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0.12 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0.12 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.5" radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
  </link>
  <joint name="chassis_to_left_rear_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_left_rear_pillar"/>
    <origin xyz="${wheelbase/2 - 0.30} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Rear hoop: right upright -->
  <link name="roll_cage_right_rear_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0.12 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0.12 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.5" radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
  </link>
  <joint name="chassis_to_right_rear_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_right_rear_pillar"/>
    <origin xyz="${wheelbase/2 - 0.30} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Rear hoop: top cross bar -->
  <link name="roll_cage_rear_hoop">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="1.5" radius="${cage_tube_radius}" length="${chassis_width + 0.1}"/>
  </link>
  <joint name="chassis_to_rear_hoop" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_rear_hoop"/>
    <origin xyz="${wheelbase/2 - 0.30} 0 ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- ── A-PILLAR (front cage uprights connecting front hoop to chassis sides) -->
  <!-- Preserved names from original for Gazebo/abaja_buggy.urdf.xacro compatibility -->
  <link name="roll_cage_left_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cage_tube_radius}" length="${cage_height}"/>
  </link>
  <joint name="chassis_to_left_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_left_pillar"/>
    <origin xyz="${wheelbase/2 + 0.12} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <link name="roll_cage_right_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height}"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="${cage_height}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cage_tube_radius}" length="${cage_height}"/>
  </link>
  <joint name="chassis_to_right_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_right_pillar"/>
    <origin xyz="${wheelbase/2 + 0.12} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── TOP CONNECTING BAR (front hoop to rear hoop, left and right) ── -->
  <link name="roll_cage_top_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.90"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.90"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="1.5" radius="${cage_tube_radius}" length="0.90"/>
  </link>
  <joint name="chassis_to_top_bar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_top_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} 0 ${chassis_height/2 + cage_height + 0.025}" rpy="0 0 0"/>
  </joint>

  <!-- Top left longtudinal bar -->
  <link name="roll_cage_left_side_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.85"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.85"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="1.5" radius="${cage_tube_radius}" length="0.85"/>
  </link>
  <joint name="chassis_to_left_side_bar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_left_side_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- Top right longitudinal bar -->
  <link name="roll_cage_right_side_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.85"/></geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="${cage_tube_radius}" length="0.85"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="1.5" radius="${cage_tube_radius}" length="0.85"/>
  </link>
  <joint name="chassis_to_right_side_bar" type="fixed">
    <parent link="chassis_link"/>
    <child  link="roll_cage_right_side_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- ── DIAGONAL BRACES (X-brace pattern at rear of roll cage) ── -->
  <xacro:cage_tube
    link_name="roll_cage_diag_left"
    tube_len="0.80"
    tube_mass="1.0"
    parent_link="chassis_link"
    jnt_x="${wheelbase/2 + 0.12}" jnt_y="${chassis_width/2 + 0.03}" jnt_z="${chassis_height/2 + cage_height * 0.60}"
    jnt_r="0" jnt_p="0" jnt_yaw="0"
    vis_r="0" vis_p="0.52" vis_yaw="0"/>

  <xacro:cage_tube
    link_name="roll_cage_diag_right"
    tube_len="0.80"
    tube_mass="1.0"
    parent_link="chassis_link"
    jnt_x="${wheelbase/2 + 0.12}" jnt_y="-${chassis_width/2 + 0.03}" jnt_z="${chassis_height/2 + cage_height * 0.60}"
    jnt_r="0" jnt_p="0" jnt_yaw="0"
    vis_r="0" vis_p="0.52" vis_yaw="0"/>

  <!-- ── SIDE PROTECTION BARS (low horizontal tube along body sides) ── -->
  <xacro:cage_tube
    link_name="side_protection_left"
    tube_len="1.20"
    tube_mass="2.0"
    parent_link="chassis_link"
    jnt_x="${wheelbase/2}" jnt_y="${chassis_width/2 + 0.07}" jnt_z="${chassis_height/2 + 0.18}"
