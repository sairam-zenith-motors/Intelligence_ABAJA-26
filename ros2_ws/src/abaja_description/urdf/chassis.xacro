<?xml version="1.0"?>
<!-- ============================================================================
  chassis.xacro - Chassis, body, roll cage, seat, and electronics for aBAJA Buggy
  
  This file defines the main structural components of the buggy:
  - base_link (ground reference)
  - chassis_link (main body frame)
  - roll_cage_link (tubular safety cage)  
  - floor_pan_link
  - left/right body panels
  - seat_link (driver seat)
  - steering_column_link
  - battery_box_link
  - electronics_box_link
  - front/rear suspension arms
  - sensor mount bar on top of roll cage
  - blue ASAL beacon and orange warning beacon
  
  Vehicle Dimensions (approximate from real buggy):
    Length:  2.30 m
    Width:   1.45 m  
    Height:  1.65 m
    Wheelbase: 1.65 m
    Track width: 1.25 m
    Ground clearance: ~0.25 m
============================================================================ -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="abaja_chassis">

  <!-- ======================================================================
    XACRO PROPERTIES - Vehicle dimensions as reusable constants
    Modify these values to adjust the entire model proportionally
  ====================================================================== -->
  <xacro:property name="chassis_length" value="2.0"/>
  <xacro:property name="chassis_width" value="0.85"/>
  <xacro:property name="chassis_height" value="0.15"/>
  <xacro:property name="chassis_mass" value="80.0"/>
  <xacro:property name="ground_clearance" value="0.25"/>
  
  <!-- Wheelbase and track -->
  <xacro:property name="wheelbase" value="1.65"/>
  <xacro:property name="track_width" value="1.25"/>
  
  <!-- Roll cage dimensions -->
  <xacro:property name="cage_tube_radius" value="0.025"/>
  <xacro:property name="cage_height" value="1.15"/>
  
  <!-- Cockpit position (center of cockpit relative to chassis center) -->
  <xacro:property name="cockpit_offset_x" value="0.1"/>

  <!-- ======================================================================
    INERTIA MACRO - Helper to generate inertial properties for box shapes
    
    This simplifies adding physics properties to every link.
    Parameters: mass, x_dim, y_dim, z_dim
  ====================================================================== -->
  <xacro:macro name="box_inertia" params="mass x_dim y_dim z_dim">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y_dim*y_dim + z_dim*z_dim)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(1.0/12.0) * mass * (x_dim*x_dim + z_dim*z_dim)}"
        iyz="0.0"
        izz="${(1.0/12.0) * mass * (x_dim*x_dim + y_dim*y_dim)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        iyz="0.0"
        izz="${(1.0/2.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(2.0/5.0) * mass * radius * radius}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(2.0/5.0) * mass * radius * radius}"
        iyz="0.0"
        izz="${(2.0/5.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- ======================================================================
    BASE_LINK - The reference frame at the center of the rear axle on ground
    
    This is the standard ROS convention: base_link is at ground level,
    centered between the rear wheels. All other links are relative to this.
  ====================================================================== -->
  <link name="dummy_root">
    <!-- Massless root link to satisfy KDL's requirement that the root link cannot have inertia -->
  </link>

  <joint name="dummy_to_base" type="fixed">
    <parent link="dummy_root"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    BASE_LINK - The reference frame at the center of the rear axle on ground
    
    This is the standard ROS convention: base_link is at ground level,
    centered between the rear wheels. All other links are relative to this.
  ====================================================================== -->
  <link name="base_link">
    <!-- base_link needs a small inertia so Gazebo doesn't lump it and drop its joints -->
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <!-- ======================================================================
    BASE_FOOTPRINT - Optional ground-level reference (some nav stacks use this)
  ====================================================================== -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -${ground_clearance + 0.32}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    CHASSIS_LINK - Main body frame / floor pan of the buggy
    
    This is the main structural frame. It's positioned above base_link
    at ground_clearance height. The chassis extends forward from the 
    rear axle by the wheelbase distance.
  ====================================================================== -->
  <link name="chassis_link">
    <visual>
      <origin xyz="${wheelbase/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="Black"/>
    </visual>
    <collision>
      <origin xyz="${wheelbase/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="${chassis_mass}" x_dim="${chassis_length}" y_dim="${chassis_width}" z_dim="${chassis_height}"/>
  </link>

  <!-- Fixed joint: base_link -> chassis (chassis is above ground) -->
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 ${ground_clearance}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    FLOOR PAN - The flat bottom plate of the cockpit area
  ====================================================================== -->
  <link name="floor_pan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 ${chassis_width} 0.02"/>
      </geometry>
      <material name="FloorGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 ${chassis_width} 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="8.0" x_dim="1.0" y_dim="${chassis_width}" z_dim="0.02"/>
  </link>

  <joint name="chassis_to_floor" type="fixed">
    <parent link="chassis_link"/>
    <child link="floor_pan_link"/>
    <origin xyz="${wheelbase/2 + 0.1} 0 ${chassis_height/2 + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    BODY PANELS - Left and right side panels (black sheet metal)
    These are the distinctive side panels visible in the photos
  ====================================================================== -->
  <!-- Left body panel -->
  <link name="left_body_panel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.1 0.02 0.45"/>
      </geometry>
      <material name="BodyPanel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.1 0.02 0.45"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="3.0" x_dim="1.1" y_dim="0.02" z_dim="0.45"/>
  </link>

  <joint name="chassis_to_left_panel" type="fixed">
    <parent link="chassis_link"/>
    <child link="left_body_panel_link"/>
    <origin xyz="${wheelbase/2 + 0.05} ${chassis_width/2} ${chassis_height/2 + 0.25}" rpy="0 0 0"/>
  </joint>

  <!-- Right body panel -->
  <link name="right_body_panel_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.1 0.02 0.45"/>
      </geometry>
      <material name="BodyPanel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.1 0.02 0.45"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="3.0" x_dim="1.1" y_dim="0.02" z_dim="0.45"/>
  </link>

  <joint name="chassis_to_right_panel" type="fixed">
    <parent link="chassis_link"/>
    <child link="right_body_panel_link"/>
    <origin xyz="${wheelbase/2 + 0.05} -${chassis_width/2} ${chassis_height/2 + 0.25}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    ROLL CAGE - The distinctive tubular safety cage
    
    Modeled as a set of cylindrical tubes forming the main structure.
    The real buggy has a complex welded tube frame - we approximate it
    with the main visible members.
  ====================================================================== -->
  
  <!-- Main roll cage - front hoop (A-pillar area) -->
  <link name="roll_cage_front_hoop">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 ${chassis_width + 0.1} 0.05"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 ${chassis_width + 0.1} 0.05"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.05" y_dim="${chassis_width + 0.1}" z_dim="0.05"/>
  </link>

  <joint name="chassis_to_front_hoop" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_front_hoop"/>
    <origin xyz="${wheelbase/2 + 0.55} 0 ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- Main roll cage - rear hoop -->
  <link name="roll_cage_rear_hoop">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 ${chassis_width + 0.1} 0.05"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 ${chassis_width + 0.1} 0.05"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.05" y_dim="${chassis_width + 0.1}" z_dim="0.05"/>
  </link>

  <joint name="chassis_to_rear_hoop" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_rear_hoop"/>
    <origin xyz="${wheelbase/2 - 0.3} 0 ${chassis_height/2 + cage_height}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - top bar (connects front and rear hoops) -->
  <link name="roll_cage_top_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.9 0.05 0.05"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.9 0.05 0.05"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.9" y_dim="0.05" z_dim="0.05"/>
  </link>

  <joint name="chassis_to_top_bar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_top_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} 0 ${chassis_height/2 + cage_height + 0.025}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - left pillar (A-pillar) -->
  <link name="roll_cage_left_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cage_tube_radius}" length="${cage_height}"/>
  </link>

  <joint name="chassis_to_left_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_left_pillar"/>
    <origin xyz="${wheelbase/2 + 0.55} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - right pillar -->
  <link name="roll_cage_right_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cage_tube_radius}" length="${cage_height}"/>
  </link>

  <joint name="chassis_to_right_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_right_pillar"/>
    <origin xyz="${wheelbase/2 + 0.55} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - left rear pillar -->
  <link name="roll_cage_left_rear_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0.15 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0.15 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.5" radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
  </link>

  <joint name="chassis_to_left_rear_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_left_rear_pillar"/>
    <origin xyz="${wheelbase/2 - 0.3} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - right rear pillar -->
  <link name="roll_cage_right_rear_pillar">
    <visual>
      <origin xyz="0 0 0" rpy="0.15 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0.15 0 0"/>
      <geometry>
        <cylinder radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.5" radius="${cage_tube_radius}" length="${cage_height + 0.15}"/>
  </link>

  <joint name="chassis_to_right_rear_pillar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_right_rear_pillar"/>
    <origin xyz="${wheelbase/2 - 0.3} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - side bars (left) -->
  <link name="roll_cage_left_side_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 ${cage_tube_radius*2} ${cage_tube_radius*2}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 ${cage_tube_radius*2} ${cage_tube_radius*2}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.85" y_dim="${cage_tube_radius*2}" z_dim="${cage_tube_radius*2}"/>
  </link>

  <joint name="chassis_to_left_side_bar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_left_side_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} ${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height * 0.55}" rpy="0 0 0"/>
  </joint>

  <!-- Roll cage - side bars (right) -->
  <link name="roll_cage_right_side_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 ${cage_tube_radius*2} ${cage_tube_radius*2}"/>
      </geometry>
      <material name="Steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.85 ${cage_tube_radius*2} ${cage_tube_radius*2}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.85" y_dim="${cage_tube_radius*2}" z_dim="${cage_tube_radius*2}"/>
  </link>

  <joint name="chassis_to_right_side_bar" type="fixed">
    <parent link="chassis_link"/>
    <child link="roll_cage_right_side_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} -${chassis_width/2 + 0.03} ${chassis_height/2 + cage_height * 0.55}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    SENSOR MOUNT BAR - The horizontal bar on top of the roll cage
    Used for mounting beacons, camera, and other sensors
  ====================================================================== -->
  <link name="sensor_mount_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.7 0.04"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.7 0.04"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.4" y_dim="0.7" z_dim="0.04"/>
  </link>

  <joint name="cage_to_sensor_bar" type="fixed">
    <parent link="chassis_link"/>
    <child link="sensor_mount_bar"/>
    <origin xyz="${wheelbase/2 + 0.12} 0 ${chassis_height/2 + cage_height + 0.07}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    BEACONS - Blue ASAL (Autonomous) and Orange Warning beacons
    These are the distinctive lights visible on top of the real buggy
  ====================================================================== -->
  
  <!-- Blue ASAL Beacon (left side on top) -->
  <link name="asal_beacon_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
      <material name="Blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.3" radius="0.06" length="0.1"/>
  </link>

  <!-- Beacon dome (sphere on top) -->
  <link name="asal_beacon_dome">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="Blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia mass="0.1" radius="0.055"/>
  </link>

  <joint name="sensor_bar_to_asal_beacon" type="fixed">
    <parent link="sensor_mount_bar"/>
    <child link="asal_beacon_link"/>
    <origin xyz="0.05 0.15 0.07" rpy="0 0 0"/>
  </joint>

  <joint name="asal_beacon_to_dome" type="fixed">
    <parent link="asal_beacon_link"/>
    <child link="asal_beacon_dome"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- Orange Warning Beacon (right side on top) -->
  <link name="warning_beacon_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
      <material name="Amber"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.1"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.3" radius="0.06" length="0.1"/>
  </link>

  <link name="warning_beacon_dome">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="Amber"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia mass="0.1" radius="0.055"/>
  </link>

  <joint name="sensor_bar_to_warning_beacon" type="fixed">
    <parent link="sensor_mount_bar"/>
    <child link="warning_beacon_link"/>
    <origin xyz="0.05 -0.15 0.07" rpy="0 0 0"/>
  </joint>

  <joint name="warning_beacon_to_dome" type="fixed">
    <parent link="warning_beacon_link"/>
    <child link="warning_beacon_dome"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    SEAT - Driver seat (the black seat with red harness visible in photos)
  ====================================================================== -->
  <link name="seat_link">
    <!-- Seat bottom -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.42 0.4 0.08"/>
      </geometry>
      <material name="SeatBlack"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.42 0.4 0.08"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="3.0" x_dim="0.42" y_dim="0.4" z_dim="0.08"/>
  </link>

  <!-- Seat backrest -->
  <link name="seat_backrest_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.38 0.5"/>
      </geometry>
      <material name="SeatBlack"/>
    </visual>
    <!-- Red harness stripe -->
    <visual>
      <origin xyz="0.01 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.08 0.48"/>
      </geometry>
      <material name="SeatRed"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.38 0.5"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="2.0" x_dim="0.06" y_dim="0.38" z_dim="0.5"/>
  </link>

  <joint name="chassis_to_seat" type="fixed">
    <parent link="chassis_link"/>
    <child link="seat_link"/>
    <origin xyz="${wheelbase/2 + 0.2} 0 ${chassis_height/2 + 0.12}" rpy="0 0 0"/>
  </joint>

  <joint name="seat_to_backrest" type="fixed">
    <parent link="seat_link"/>
    <child link="seat_backrest_link"/>
    <origin xyz="-0.2 0 0.29" rpy="0 -0.1 0"/>
  </joint>

  <!-- ======================================================================
    STEERING COLUMN - Simplified steering wheel area
  ====================================================================== -->
  <link name="steering_column_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0.5 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.35"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0.5 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.35"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.5" radius="0.015" length="0.35"/>
  </link>

  <!-- Steering wheel -->
  <link name="steering_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.025"/>
      </geometry>
      <material name="SteeringBlack"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.14" length="0.025"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.14" length="0.025"/>
  </link>

  <joint name="chassis_to_steering_column" type="fixed">
    <parent link="chassis_link"/>
    <child link="steering_column_link"/>
    <origin xyz="${wheelbase/2 + 0.55} 0 ${chassis_height/2 + 0.35}" rpy="0 0 0"/>
  </joint>

  <joint name="column_to_wheel" type="fixed">
    <parent link="steering_column_link"/>
    <child link="steering_wheel_link"/>
    <origin xyz="0.12 0 0.12" rpy="0 0.5 0"/>
  </joint>

  <!-- ======================================================================
    BATTERY BOX - The battery/energy storage visible in the rear
    (Yellow hazard marking visible in the rear photos)
  ====================================================================== -->
  <link name="battery_box_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.3 0.2"/>
      </geometry>
      <material name="BatteryYellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.3 0.2"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="25.0" x_dim="0.35" y_dim="0.3" z_dim="0.2"/>
  </link>

  <joint name="chassis_to_battery" type="fixed">
    <parent link="chassis_link"/>
    <child link="battery_box_link"/>
    <origin xyz="${wheelbase/2 - 0.5} 0 ${chassis_height/2 + 0.15}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    ELECTRONICS BOX - Motor controller, wiring harness, etc.
    (The wiring/electronics visible behind the cockpit)
  ====================================================================== -->
  <link name="electronics_box_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.5 0.25"/>
      </geometry>
      <material name="ElectronicsGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.5 0.25"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="10.0" x_dim="0.3" y_dim="0.5" z_dim="0.25"/>
  </link>

  <joint name="chassis_to_electronics" type="fixed">
    <parent link="chassis_link"/>
    <child link="electronics_box_link"/>
    <origin xyz="${wheelbase/2 - 0.15} 0 ${chassis_height/2 + 0.45}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    REAR LIGHTS - Tail lights visible in rear photos
  ====================================================================== -->
  <link name="left_tail_light">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="Red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.1" radius="0.05" length="0.03"/>
  </link>

  <link name="right_tail_light">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="Red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.1" radius="0.05" length="0.03"/>
  </link>

  <joint name="chassis_to_left_tail_light" type="fixed">
    <parent link="chassis_link"/>
    <child link="left_tail_light"/>
    <origin xyz="${wheelbase/2 - 0.65} 0.15 ${chassis_height/2 + 0.75}" rpy="0 0 0"/>
  </joint>

  <joint name="chassis_to_right_tail_light" type="fixed">
    <parent link="chassis_link"/>
    <child link="right_tail_light"/>
    <origin xyz="${wheelbase/2 - 0.65} -0.15 ${chassis_height/2 + 0.75}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================================
    SUSPENSION ARMS - Simplified A-arm / wishbone representation
    With red/orange spring-shock absorbers visible on the real buggy
  ====================================================================== -->

  <!-- Front left suspension arm -->
  <link name="front_left_suspension_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.35" y_dim="0.04" z_dim="0.04"/>
  </link>

  <joint name="chassis_to_fl_suspension" type="fixed">
    <parent link="chassis_link"/>
    <child link="front_left_suspension_arm"/>
    <origin xyz="${wheelbase} ${chassis_width/2 + 0.08} -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Front left spring/shock (RED) -->
  <link name="front_left_spring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
      <material name="Red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.025" length="0.25"/>
  </link>

  <joint name="chassis_to_fl_spring" type="fixed">
    <parent link="chassis_link"/>
    <child link="front_left_spring"/>
    <origin xyz="${wheelbase - 0.05} ${chassis_width/2 + 0.05} ${-chassis_height/2 + 0.05}" rpy="0 0.2 0"/>
  </joint>

  <!-- Front right suspension arm -->
  <link name="front_right_suspension_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.35" y_dim="0.04" z_dim="0.04"/>
  </link>

  <joint name="chassis_to_fr_suspension" type="fixed">
    <parent link="chassis_link"/>
    <child link="front_right_suspension_arm"/>
    <origin xyz="${wheelbase} -${chassis_width/2 + 0.08} -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Front right spring/shock (RED) -->
  <link name="front_right_spring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
      <material name="Red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.025" length="0.25"/>
  </link>

  <joint name="chassis_to_fr_spring" type="fixed">
    <parent link="chassis_link"/>
    <child link="front_right_spring"/>
    <origin xyz="${wheelbase - 0.05} -${chassis_width/2 + 0.05} ${-chassis_height/2 + 0.05}" rpy="0 0.2 0"/>
  </joint>

  <!-- Rear left suspension arm -->
  <link name="rear_left_suspension_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.35" y_dim="0.04" z_dim="0.04"/>
  </link>

  <joint name="chassis_to_rl_suspension" type="fixed">
    <parent link="chassis_link"/>
    <child link="rear_left_suspension_arm"/>
    <origin xyz="0 ${chassis_width/2 + 0.08} -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Rear left spring/shock (ORANGE - visible in rear photos) -->
  <link name="rear_left_spring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.025" length="0.25"/>
  </link>

  <joint name="chassis_to_rl_spring" type="fixed">
    <parent link="chassis_link"/>
    <child link="rear_left_spring"/>
    <origin xyz="-0.05 ${chassis_width/2 + 0.05} ${-chassis_height/2 + 0.05}" rpy="0 -0.2 0"/>
  </joint>

  <!-- Rear right suspension arm -->
  <link name="rear_right_suspension_arm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 -0.3"/>
      <geometry>
        <box size="0.35 0.04 0.04"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.5" x_dim="0.35" y_dim="0.04" z_dim="0.04"/>
  </link>

  <joint name="chassis_to_rr_suspension" type="fixed">
    <parent link="chassis_link"/>
    <child link="rear_right_suspension_arm"/>
    <origin xyz="0 -${chassis_width/2 + 0.08} -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Rear right spring/shock (ORANGE) -->
  <link name="rear_right_spring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.25"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.8" radius="0.025" length="0.25"/>
  </link>

  <joint name="chassis_to_rr_spring" type="fixed">
    <parent link="chassis_link"/>
    <child link="rear_right_spring"/>
    <origin xyz="-0.05 -${chassis_width/2 + 0.05} ${-chassis_height/2 + 0.05}" rpy="0 -0.2 0"/>
  </joint>

  <!-- ======================================================================
    REAR SUBFRAME - Motor/drivetrain mount area
  ====================================================================== -->
  <link name="rear_subframe_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.6 0.1"/>
      </geometry>
      <material name="DarkGrey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.6 0.1"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="12.0" x_dim="0.5" y_dim="0.6" z_dim="0.1"/>
  </link>

  <joint name="chassis_to_rear_subframe" type="fixed">
    <parent link="chassis_link"/>
    <child link="rear_subframe_link"/>
    <origin xyz="-0.15 0 -${chassis_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

</robot>
