    vis_r="0" vis_p="${pi/2}" vis_yaw="0"/>

  <!-- ======================================================================
    SENSOR MOUNT BAR (preserved name/joint)
  ====================================================================== -->
  <link name="sensor_mount_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.45 0.75 0.05"/></geometry>
